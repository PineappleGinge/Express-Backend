@email = joe99@gmail.com
@password = password

# @name createUser
POST http://localhost:3000/api/v1/users HTTP/3.0
content-type: application/json

{
  "name": "Joe",
  "email": "{{email}}",
  "phonenumber": "0871234567",
  "dob": "2000-01-01",
  "password": "{{password}}",
  "role": "admin"
}
###

# @name login
POST http://localhost:3000/api/v1/auth HTTP/3.0
content-type: application/json

{ 
  "email": "{{email}}",
  "password": "{{password}}"
}
###
@accessToken = {{login.response.body.accessToken}}

###
POST http://localhost:3000/api/v1/users HTTP/3.0
content-type: application/json

{ "name" : "Admin ",
   "email": "ad@gmail.com",
   "phonenumber": "0876543210",
   "password" : "password",
   "role": "admin"
}
### POST Request for a login
## Expected result is a token with a payload that inlcudes a role of admin
# @name loginAdmin
POST http://localhost:3000/api/v1/auth HTTP/3.0
content-type: application/json

{
   "email": "ad@gmail.com",
   "password" : "password"
}

